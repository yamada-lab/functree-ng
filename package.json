{
  "name": "functree-ng",
  "description": "FuncTree2: an interactive radial tree for functional hierarchies and omics data visualization",
  "author": {
    "name": "Yuta Yamate",
    "url": "https://github.com/yutayamate"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yamada-lab/functree-ng.git"
  },
  "bugs": {
    "url": "https://github.com/yamada-lab/functree-ng/issues"
  },
  "license": "MIT",
  "dependencies": {
    "axios": "^0.21.1",
    "bootstrap": "^3.3.7",
    "bootstrap-menu": "^1.0.14",
    "corejs-typeahead": "^1.2.1",
    "d3": "^3.5.17",
    "datatables.net": "^1.10.19",
    "datatables.net-bs": "^1.10.19",
    "datatables.net-buttons": "^1.3.1",
    "font-awesome": "^4.7.0",
    "highcharts": "^9.0.1",
    "jquery": "^3.2.1",
    "particles.js": "^2.0.0",
    "vue": "^2.4.2",
    "vue-color": "2.7.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "sass": "^1.71.0"
  },
  "scripts": {
    "install-depends": "yarn install --production=true --modules-folder functree/static/yarn_components",
    "install-devDepends": "yarn install --production=false",
    "babel": "babel functree/static/src/js --out-dir functree/static/dist/js",
    "babel:watch": "babel --watch functree/static/src/js --out-dir functree/static/dist/js",
    "sass": "sass functree/static/src/scss:functree/static/dist/css --style=compressed --no-source-map",
    "sass:watch": "sass --watch functree/static/src/scss:functree/static/dist/css --style=compressed",
    "build": "yarn sass && yarn babel"
  },
  "private": true
}
